# =============================================================================
# Alhazen Dashboard — Lightweight base image for plugin users
# =============================================================================
# Builds a dashboard with just the hub page and TypeDB status.
# Skill-specific pages are wired in later via `alhazen_core.py wire-dashboard`.
#
# Build context: this directory (skills/alhazen-core/)
# The Dockerfile clones skillful-alhazen to get the dashboard source.
# =============================================================================

# Stage 1: Clone dashboard source from skillful-alhazen
FROM alpine/git AS dashboard-src
ARG REPO=https://github.com/sciknow-io/skillful-alhazen.git
ARG REF=main
RUN git clone --depth=1 --branch $REF $REPO /src

# Stage 2: Node.js — install deps only, NO build
# Build happens later via `alhazen_core.py rebuild-dashboard` after skills are wired in.
FROM node:20-slim AS deps
WORKDIR /app
COPY --from=dashboard-src /src/dashboard/package*.json ./
RUN ELECTRON_SKIP_BINARY_DOWNLOAD=1 npm ci
COPY --from=dashboard-src /src/dashboard/ ./

# No skill dashboards baked in — all arrive via wire-dashboard + rebuild-dashboard
RUN echo '[]' > public/skills-config.json
RUN echo '[]' > public/skills-config.json
RUN echo '{}' > public/namespace-config.json

# Stage 3: Runtime (Node.js + Python + uv)
FROM python:3.11-slim AS runner

# Install Node.js and curl
RUN apt-get update && \
    apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /app

# Copy source + node_modules (NOT a built .next — build happens after wiring)
COPY --from=deps /app/ ./

# Create directories for skill wiring
RUN mkdir -p .claude/skills

# Environment
ENV NEXT_TELEMETRY_DISABLED=1
ENV TYPEDB_HOST=typedb
ENV TYPEDB_PORT=1729
ENV TYPEDB_DATABASE=alhazen_notebook
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

EXPOSE 3000

# Start with a placeholder that waits for rebuild-dashboard to produce .next/
# After rebuild-dashboard runs, the container restarts with the built app.
CMD ["sh", "-c", "if [ -d .next ]; then npm start; else echo 'Dashboard not yet built. Run: alhazen_core.py rebuild-dashboard' && sleep infinity; fi"]
